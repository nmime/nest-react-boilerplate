{
  "name": "@app/postgres-main-auth",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/postgres/main/auth/lib/src",
  "projectType": "library",
  "tags": [
    "platform:backend",
    "type:data-access",
    "scope:postgres",
    "scope:auth"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/postgres/main/auth",
        "main": "libs/postgres/main/auth/lib/src/index.ts",
        "tsConfig": "libs/postgres/main/auth/lib/tsconfig.lib.json",
        "assets": []
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "cwd": "libs/postgres/main/auth/lib",
        "command": "vitest run --config vitest.config.mts"
      },
      "inputs": [
        "default",
        "^production",
        {
          "externalDependencies": ["vitest"]
        }
      ],
      "outputs": ["{workspaceRoot}/coverage/libs/postgres/main/auth"]
    },
    "component-test": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "cwd": "libs/postgres/main/auth/lib",
        "command": "vitest run --config vitest.component.config.mts"
      },
      "inputs": [
        "default",
        "^production",
        {
          "externalDependencies": [
            "vitest",
            "testcontainers",
            "@testcontainers/postgresql"
          ]
        }
      ],
      "outputs": ["{workspaceRoot}/coverage/libs/postgres/main/auth-component"]
    }
  }
}
