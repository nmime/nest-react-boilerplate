{
  "name": "@app/backend/bots/discord",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/backend/bots/discord/lib/src",
  "projectType": "library",
  "tags": ["platform:backend", "type:common", "scope:discord"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/backend/bots/discord",
        "main": "libs/backend/bots/discord/lib/src/index.ts",
        "tsConfig": "libs/backend/bots/discord/lib/tsconfig.lib.json",
        "assets": [],
        "rootDir": "."
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "cwd": "libs/backend/bots/discord/lib",
        "command": "vitest run --config vitest.config.mts"
      },
      "inputs": [
        "default",
        "^production",
        {
          "externalDependencies": ["vitest"]
        }
      ],
      "outputs": ["{workspaceRoot}/coverage/libs/backend/bots/discord"]
    }
  }
}
