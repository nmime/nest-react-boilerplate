{
  "name": "admin-app",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/frontend/admin/src",
  "projectType": "application",
  "tags": [
    "platform:frontend",
    "type:admin-app",
    "type:frontend-app",
    "scope:admin",
    "type:app"
  ],
  "// targets": "to see all targets run: nx show project admin-app --web",
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "cwd": "apps/frontend/admin",
        "command": "vitest run --config vitest.config.mts"
      },
      "inputs": [
        "default",
        "^production",
        {
          "externalDependencies": ["vitest"]
        }
      ],
      "outputs": ["{workspaceRoot}/coverage/apps/frontend/admin"]
    },
    "e2e": {
      "executor": "nx:run-commands",
      "cache": true,
      "dependsOn": ["build"],
      "options": {
        "command": "node tools/frontend-static-smoke.mjs --dist dist/apps/frontend/admin --app-name admin-app --contains \"Operate the xRocket platform with a unified admin experience.\""
      },
      "inputs": [
        "production",
        {
          "externalDependencies": []
        }
      ],
      "outputs": []
    }
  }
}
