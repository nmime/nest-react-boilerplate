{
  "name": "boilerplate",
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "typecheck": "turbo run typecheck",
    "deps": "turbo run deps",
    "prepare": "pnpm run setup:env",
    "setup:env": "pnpm --filter api --filter admin-shadcn --filter @workspace/database exec cp .env.example .env"
  },
  "devDependencies": {
    "@infra-x/code-quality": "^0.6.2",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "storybook": "^10.3.6"
  },
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
  "pnpm": {
    "peerDependencyRules": {
      "allowAny": [
        "openapi-fetch",
        "storybook"
      ]
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@scarf/scarf",
      "@swc/core",
      "bcrypt",
      "better-sqlite3",
      "esbuild",
      "msw"
    ],
    "overrides": {
      "typescript": "5.9.3",
      "storybook": "10.3.6",
      "@swc/cli": "0.7.10"
    },
    "ignoredBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  },
  "engines": {
    "node": ">=22 <23"
  }
}
