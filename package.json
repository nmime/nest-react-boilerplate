{
  "name": "nest-react-boilerplate",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "nx": "nx",
    "dev": "nx run-many -t serve",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "test:coverage": "pnpm exec nx run-many -t test --all -- --coverage",
    "audit": "pnpm audit --audit-level=moderate",
    "test:component": "nx run-many -t component-test --all",
    "test:e2e": "nx run-many -t e2e --projects=admin-app,user-app,landing-app,backend-admin-app-api,user-app-api,auth-app-api",
    "test:e2e:coverage": "nx run-many -t e2e --projects=admin-app,user-app,landing-app,backend-admin-app-api,user-app-api,auth-app-api -- --coverage",
    "dev:db": "docker compose up -d postgres",
    "db:migrate": "node tools/db-migrate.mjs",
    "db:reset": "node tools/db-reset.mjs",
    "dev:fullstack": "node tools/dev-fullstack.mjs",
    "docker:fullstack": "docker compose -f docker/docker-compose.yml up --build",
    "docker:down": "docker compose -f docker/docker-compose.yml down --remove-orphans",
    "test:docker-smoke": "node tools/docker-smoke.mjs",
    "test:fullstack": "node tools/fullstack-e2e.mjs",
    "check": "pnpm run format:check && pnpm run api:contracts:check && pnpm run api:clients:check && pnpm run lint && pnpm run typecheck && pnpm run test",
    "init:project": "node tools/init-project.mjs",
    "db:seed": "node tools/db-seed.mjs",
    "db:backup": "node tools/db-backup.mjs",
    "db:restore": "node tools/db-restore.mjs",
    "api:openapi": "node tools/export-openapi.mjs",
    "api:client": "node tools/generate-api-clients.mjs",
    "api:contracts": "node tools/generate-api-contracts.mjs",
    "api:contracts:check": "node tools/check-api-contracts.mjs",
    "api:clients": "node tools/generate-api-clients.mjs",
    "api:clients:check": "node tools/check-api-clients.mjs"
  },
  "dependencies": {
    "@mikro-orm/core": "7.0.16",
    "@mikro-orm/migrations": "7.0.16",
    "@mikro-orm/nestjs": "7.0.1",
    "@mikro-orm/postgresql": "7.0.16",
    "@nestjs/common": "11.1.21",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.21",
    "@nestjs/platform-express": "11.1.21",
    "@nestjs/swagger": "11.4.3",
    "@tanstack/react-query": "^5.100.10",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "cookie-parser": "1.4.7",
    "dataloader": "2.2.3",
    "helmet": "8.1.0",
    "mobx": "^6.15.3",
    "mobx-react-lite": "^4.1.1",
    "nestjs-i18n": "10.8.4",
    "neverthrow": "8.2.0",
    "openapi-fetch": "^0.14.1",
    "openapi-react-query": "^0.5.4",
    "openid-client": "6.8.4",
    "pg": "8.20.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@nestjs/testing": "11.1.21",
    "@nx/devkit": "22.7.1",
    "@nx/eslint": "22.7.1",
    "@nx/eslint-plugin": "22.7.1",
    "@nx/jest": "22.7.1",
    "@nx/js": "22.7.1",
    "@nx/nest": "22.7.1",
    "@nx/node": "22.7.1",
    "@nx/react": "22.7.1",
    "@nx/vite": "22.7.1",
    "@nx/web": "22.7.1",
    "@nx/webpack": "22.7.1",
    "@playwright/test": "1.60.0",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.33",
    "@swc/helpers": "0.5.21",
    "@testcontainers/postgresql": "11.14.0",
    "@testing-library/react": "16.3.2",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "25.7.0",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/supertest": "7.2.0",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.6",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-sonarjs": "4.0.3",
    "istanbul-lib-coverage": "3.2.2",
    "istanbul-lib-report": "3.0.1",
    "istanbul-reports": "3.2.0",
    "jest": "30.4.2",
    "jest-environment-node": "30.4.1",
    "jest-junit": "17.0.0",
    "jest-util": "30.4.1",
    "jiti": "2.7.0",
    "jsdom": "29.1.1",
    "jsonc-eslint-parser": "3.1.0",
    "nx": "22.7.1",
    "openapi-typescript": "^7.13.0",
    "postcss": "8.5.14",
    "prettier": "3.8.3",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "testcontainers": "11.14.0",
    "ts-jest": "29.4.9",
    "ts-loader": "9.5.7",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "typescript-transform-paths": "3.5.6",
    "vite": "8.0.13",
    "vite-plugin-istanbul": "8.0.0",
    "vitest": "4.1.6",
    "webpack-cli": "7.0.2"
  },
  "pnpm": {
    "overrides": {
      "typescript": "6.0.3",
      "rxjs": "7.8.2",
      "tslib": "2.8.1",
      "lodash": "4.18.1",
      "brace-expansion@<2.0.0": "1.1.14",
      "brace-expansion@>=2.0.0 <3.0.0": "2.1.0",
      "picomatch@<3.0.0": "2.3.2",
      "picomatch@>=4.0.0 <5.0.0": "4.0.4",
      "path-to-regexp@>=8.0.0 <9.0.0": "8.4.2",
      "serialize-javascript": "7.0.5",
      "postcss": "8.5.14",
      "follow-redirects": "1.16.0",
      "axios": "1.16.1",
      "fast-uri": "3.1.2",
      "svgo@>=3.0.0 <4.0.0": "3.3.3",
      "js-yaml": "4.1.1",
      "brace-expansion@>=4.0.0 <6.0.0": "5.0.6",
      "yaml": "2.9.0",
      "ajv@>=7.0.0 <9.0.0": "8.20.0"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "nx"
    ],
    "ignoredBuiltDependencies": [
      "@scarf/scarf",
      "less",
      "unrs-resolver"
    ]
  },
  "engines": {
    "node": ">=26 <27"
  },
  "author": {
    "name": "nmime",
    "url": "https://github.com/nmime"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nmime/nest-react-boilerplate.git"
  },
  "bugs": {
    "url": "https://github.com/nmime/nest-react-boilerplate/issues"
  },
  "homepage": "https://github.com/nmime/nest-react-boilerplate#readme"
}
