{
  "name": "@app/frontend-ui",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/frontend/ui/lib/src",
  "projectType": "library",
  "tags": ["platform:frontend", "type:ui", "scope:shared"],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "cwd": "libs/frontend/ui/lib",
        "command": "vitest run --config vitest.config.mts"
      },
      "inputs": [
        "default",
        "^production",
        {
          "externalDependencies": ["vitest"]
        }
      ],
      "outputs": ["{workspaceRoot}/dist/libs/frontend/ui-test"]
    }
  }
}
