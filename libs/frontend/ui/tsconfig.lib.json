{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc",
    "declaration": true,
    "types": [
      "node",
      "@nx/react/typings/cssmodule.d.ts",
      "@nx/react/typings/image.d.ts",
      "vite/client"
    ]
  },
  "include": ["lib/src/**/*.ts", "lib/src/**/*.tsx"],
  "exclude": [
    "lib/src/**/*.spec.ts",
    "lib/src/**/*.test.ts",
    "lib/src/**/*.spec.tsx",
    "lib/src/**/*.test.tsx"
  ]
}
