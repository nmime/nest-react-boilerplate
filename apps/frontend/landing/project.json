{
  "name": "landing-app",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/frontend/landing/src",
  "projectType": "application",
  "tags": [
    "platform:frontend",
    "type:frontend-app",
    "scope:landing",
    "type:app"
  ],
  "// targets": "to see all targets run: nx show project landing-app --web",
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "cwd": "apps/frontend/landing",
        "command": "vitest run --config vitest.config.mts"
      },
      "inputs": [
        "default",
        "^production",
        {
          "externalDependencies": ["vitest"]
        }
      ],
      "outputs": ["{workspaceRoot}/coverage/apps/frontend/landing"]
    },
    "e2e": {
      "executor": "nx:run-commands",
      "cache": true,
      "dependsOn": ["build"],
      "options": {
        "command": "node tools/frontend-static-smoke.mjs --dist dist/apps/frontend/landing --app-name landing-app --contains \"A product front door for the xRocket ecosystem.\""
      },
      "inputs": [
        "production",
        {
          "externalDependencies": []
        }
      ],
      "outputs": []
    }
  }
}
