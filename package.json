{
  "name": "nest-react-boilerplate",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "nx": "nx",
    "dev": "nx run-many -t serve",
    "build": "VITE_API_BASE_URL_MODE=same-origin nx run-many -t build",
    "storybook": "storybook dev -p 6006 -c libs/frontend/ui/lib/.storybook",
    "storybook:build": "storybook build -c libs/frontend/ui/lib/.storybook -o dist/storybook/frontend-ui",
    "test": "nx run-many -t test",
    "test:otel": "nx run @app/common/otel:test",
    "test:storybook": "pnpm --filter @repo/tooling tooling testing storybook",
    "test:visual": "pnpm --filter @repo/tooling tooling testing storybook-visual",
    "test:visual:update": "pnpm --filter @repo/tooling tooling testing storybook-visual --update-snapshots",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown --cache --cache-location .cache/prettier/check-cache",
    "format:changed": "pnpm --filter @repo/tooling tooling tooling changed-format-check",
    "test:coverage": "pnpm exec nx run-many -t test --all -- --coverage",
    "audit": "pnpm audit --audit-level=moderate",
    "audit:ci": "pnpm audit --audit-level=moderate --prod",
    "audit:lockfile": "pnpm audit --audit-level=moderate --prod",
    "test:component": "nx run-many -t component-test --all",
    "test:e2e": "nx run-many -t e2e --projects=admin-app,user-app,landing-app,admin-app-api,user-app-api,auth-app-api",
    "test:e2e:coverage": "nx run-many -t e2e --projects=admin-app,user-app,landing-app,admin-app-api,user-app-api,auth-app-api -- --coverage",
    "dev:db": "docker compose up -d postgres",
    "db:migrate": "pnpm --filter @repo/tooling tooling db migrate",
    "db:migrations:check": "pnpm --filter @repo/tooling tooling db migrations check",
    "db:reset": "pnpm --filter @repo/tooling tooling db reset",
    "dev:fullstack": "pnpm --filter @repo/tooling tooling dev fullstack",
    "docker:fullstack": "docker compose -f docker/docker-compose.yml up --build",
    "docker:down": "docker compose -f docker/docker-compose.yml down --remove-orphans",
    "docker:prod:config:check": "node scripts/validate-docker-compose-prod.mjs",
    "deploy:validate": "node scripts/deploy-validate.mjs",
    "test:docker-smoke": "pnpm --filter @repo/tooling tooling docker smoke",
    "test:fullstack": "pnpm --filter @repo/tooling tooling docker fullstack-e2e",
    "check:fast": "pnpm run tooling:static-check && pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test",
    "check": "pnpm run format:check && pnpm run tooling:static-check && pnpm run db:migrations:check && pnpm run lib:configs:check && pnpm run api:contracts:check && pnpm run api:clients:check && pnpm run api:openapi:lint && pnpm run api:contracts:consumer && pnpm run api:openapi:fuzz && pnpm run test:property && pnpm run test:world-class && pnpm run lint && pnpm run typecheck && pnpm run test",
    "lib:configs:check": "pnpm --filter @repo/tooling tooling project check-library-configs",
    "init:project": "pnpm --filter @repo/tooling tooling project init",
    "db:seed": "pnpm --filter @repo/tooling tooling db seed",
    "db:backup": "pnpm --filter @repo/tooling tooling db backup",
    "db:restore": "pnpm --filter @repo/tooling tooling db restore",
    "api:openapi": "pnpm --filter @repo/tooling tooling api openapi",
    "api:client": "pnpm --filter @repo/tooling tooling api client",
    "api:contracts": "pnpm --filter @repo/tooling tooling api contracts",
    "api:contracts:check": "pnpm --filter @repo/tooling tooling api contracts check",
    "api:contracts:consumer": "pnpm --filter @repo/tooling tooling qa consumer-contracts",
    "api:clients": "pnpm --filter @repo/tooling tooling api clients",
    "api:clients:check": "pnpm --filter @repo/tooling tooling api clients check",
    "api:openapi:lint": "pnpm --filter @repo/tooling tooling qa openapi-lint",
    "api:openapi:fuzz": "pnpm --filter @repo/tooling tooling qa openapi-fuzz",
    "test:a11y": "pnpm --filter @repo/tooling tooling qa accessibility",
    "test:e2e:matrix": "pnpm --filter @repo/tooling tooling qa cross-browser-e2e",
    "test:perf": "pnpm --filter @repo/tooling tooling qa performance",
    "test:security:sast": "pnpm --filter @repo/tooling tooling qa security-sast",
    "test:security:secrets": "pnpm --filter @repo/tooling tooling qa secret-scan",
    "test:security:dast": "pnpm --filter @repo/tooling tooling qa security-dast",
    "test:security": "pnpm --filter @repo/tooling tooling qa security-suite",
    "security:scan": "pnpm run test:security:secrets && pnpm run test:security:sast",
    "test:mutation": "pnpm --filter @repo/tooling tooling qa mutation",
    "test:property": "pnpm --filter @repo/tooling tooling qa property",
    "test:world-class": "pnpm --filter @repo/tooling tooling qa world-class-gates",
    "test:load": "pnpm --filter @repo/tooling tooling qa world-class-gates --gate load-stress-soak",
    "test:chaos": "pnpm --filter @repo/tooling tooling qa world-class-gates --gate chaos-resilience",
    "test:disaster-recovery": "pnpm --filter @repo/tooling tooling qa world-class-gates --gate disaster-recovery",
    "test:backup-restore": "pnpm run db:restore:drill -- --ci --dry-run",
    "test:observability": "pnpm --filter @repo/tooling tooling qa world-class-gates --gate observability",
    "test:migrations:rollback": "pnpm run db:migrations:rollback-check",
    "test:concurrency": "pnpm --filter @repo/tooling tooling qa world-class-gates --gate concurrency-race",
    "test:reliability:smoke": "pnpm --filter @repo/tooling tooling qa world-class-gates --gate reliability-smoke",
    "ci:pr": "pnpm run tooling:static-check && pnpm run format:changed && pnpm run test:security:secrets && pnpm run test:security:sast && pnpm run audit:ci",
    "quality:world-class": "pnpm run test:world-class",
    "quality:presets": "pnpm run api:openapi:lint && pnpm run api:contracts:consumer && pnpm run api:openapi:fuzz && pnpm run test:property && pnpm run test:a11y && pnpm run test:e2e:matrix && pnpm run test:perf && pnpm run test:security && pnpm run test:mutation && pnpm run test:world-class",
    "db:restore:drill": "pnpm --filter @repo/tooling tooling db restore-drill",
    "test:restore-drill": "pnpm run db:restore:drill -- --ci --dry-run",
    "helm:validate": "bash scripts/validate-helm.sh",
    "generate:feature": "pnpm --filter @repo/tooling tooling project generate-vertical-slice",
    "tooling:static-check": "pnpm --filter @repo/tooling tooling tooling static-check",
    "ci:workflows:check": "node scripts/validate-github-workflows.mjs",
    "branch:cleanup:check": "pnpm --filter @repo/tooling tooling git branch-cleanup --target HEAD",
    "branch:cleanup": "pnpm --filter @repo/tooling tooling git branch-cleanup",
    "db:migrations:rollback-check": "pnpm --filter @repo/tooling tooling db migrations rollback-check",
    "frontend:fsd:check": "pnpm --filter @repo/tooling tooling frontend fsd check",
    "deploy:validate:docker": "node scripts/deploy-validate.mjs --mode=docker",
    "deploy:validate:helm": "node scripts/deploy-validate.mjs --mode=helm",
    "deploy:validate:gitops": "node scripts/deploy-validate.mjs --mode=gitops",
    "deploy:validate:pm2": "node scripts/deploy-validate.mjs --mode=pm2"
  },
  "dependencies": {
    "@casl/ability": "7.0.0",
    "@discordjs/builders": "1.14.1",
    "@discordjs/rest": "2.6.1",
    "@fastify/cookie": "11.0.2",
    "@fastify/session": "11.1.1",
    "@fastify/static": "9.1.3",
