{
  "name": "user-app",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/frontend/app/src",
  "projectType": "application",
  "tags": ["platform:frontend", "type:frontend-app", "scope:user", "type:app"],
  "// targets": "to see all targets run: nx show project user-app --web",
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "cwd": "apps/frontend/app",
        "command": "vitest run --config vitest.config.mts"
      },
      "inputs": [
        "default",
        "^production",
        {
          "externalDependencies": ["vitest"]
        }
      ],
      "outputs": ["{workspaceRoot}/coverage/apps/frontend/app"]
    },
    "e2e": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "command": "VITE_E2E_COVERAGE=true pnpm exec vite build --config apps/frontend/app/vite.config.mts && node tools/frontend-browser-e2e-coverage.mjs --dist dist/apps/frontend/app --app-name user-app --contains \"Personal crypto operations in one reliable workspace.\" --coverage-dir coverage/e2e/apps/frontend/app"
      },
      "inputs": [
        "production",
        {
          "externalDependencies": ["@playwright/test", "vite-plugin-istanbul"]
        }
      ],
      "outputs": ["{workspaceRoot}/coverage/e2e/apps/frontend/app"]
    }
  }
}
