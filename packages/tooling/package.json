{
  "name": "@repo/tooling",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Workspace-local project tooling scripts for API contracts, database operations, Docker, testing, and QA presets.",
  "bin": {
    "repo-tooling": "./bin/repo-tooling.mjs"
  },
  "scripts": {
    "tooling": "node ./bin/repo-tooling.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "static-check": "node ./bin/repo-tooling.mjs tooling static-check"
  },
  "files": [
    "bin",
    "src",
    "scripts",
    "baselines",
    "README.md",
    "tsconfig.json"
  ],
  "dependencies": {
    "jiti": "2.7.0"
  }
}
