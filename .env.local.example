OTEL_METRIC_EXPORT_INTERVAL=60000
# Optional integration setting; enable only with matching infrastructure.
OTEL_SDK_DISABLED=false
# Optional integration setting; enable only with matching infrastructure.
OTEL_SERVICE_NAME=nest-react-boilerplate-local
# Optional integration setting; enable only with matching infrastructure.
OTEL_SERVICE_VERSION=local

# PostgreSQL and MikroORM
# Required/optional runtime setting; replace placeholders per environment.
CONTAINER_DATABASE_URL=postgres://postgres:postgres@postgres:5432/nest_react_boilerplate
# Required/optional runtime setting; replace placeholders per environment.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nest_react_boilerplate
# Optional Docker/Compose/build/deploy setting.
DOCKER_DATABASE_URL=postgres://postgres:postgres@postgres:5432/nest_react_boilerplate
# Optional backup/restore setting.
POSTGRES_CLIENT_DOCKER_IMAGE=postgres:18-alpine
# Required/optional runtime setting; replace placeholders per environment.
POSTGRES_DB=nest_react_boilerplate
# Required/optional runtime setting; replace placeholders per environment.
POSTGRES_HOST=localhost
# Required/optional runtime setting; replace placeholders per environment.
POSTGRES_LOGGING=true
# Required/secret placeholder when enabled; never commit a real value.
POSTGRES_PASSWORD=postgres
# Prod-only secret-file path for Docker/Compose secret mounting.
POSTGRES_PASSWORD_FILE=
# Required/optional runtime setting; replace placeholders per environment.
POSTGRES_PORT=5432
# Required/optional runtime setting; replace placeholders per environment.
POSTGRES_SSL=false
# Required/optional runtime setting; replace placeholders per environment.
POSTGRES_SSL_REJECT_UNAUTHORIZED=true
# Required/optional runtime setting; replace placeholders per environment.
POSTGRES_USER=postgres

# Frontend builds
