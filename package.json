    "@opentelemetry/semantic-conventions": "1.41.1",
    "@tanstack/react-query": "^5.101.0",
    "@tma.js/init-data-node": "2.0.7",
    "@tma.js/sdk": "3.2.2",
    "@tma.js/sdk-react": "3.0.21",
    "arctic": "3.7.0",
    "cacheable": "2.3.5",
