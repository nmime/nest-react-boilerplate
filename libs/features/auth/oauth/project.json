{
  "name": "@app/features-auth-oauth",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/features/auth/oauth/src",
  "projectType": "library",
  "tags": ["platform:backend", "type:feature-shared"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/features/auth/oauth",
        "main": "libs/features/auth/oauth/src/index.ts",
        "tsConfig": "libs/features/auth/oauth/tsconfig.lib.json",
        "assets": []
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "cwd": "libs/features/auth/oauth",
        "command": "vitest run --config vitest.config.mts"
      },
      "inputs": [
        "default",
        "^production",
        { "externalDependencies": ["vitest"] }
      ],
      "outputs": ["{workspaceRoot}/coverage/libs/features/auth/oauth"]
    }
  }
}
