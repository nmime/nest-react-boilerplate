{
  "name": "admin-app",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/frontend/admin/src",
  "projectType": "application",
  "tags": [
    "platform:frontend",
    "type:admin-app",
    "type:frontend-app",
    "scope:admin"
  ],
  "// targets": "to see all targets run: nx show project admin-app --web",
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "cwd": "apps/frontend/admin",
        "command": "vitest run --config vitest.config.mts"
      },
      "inputs": [
        "default",
        "^production",
        {
          "externalDependencies": ["vitest"]
        }
      ],
      "outputs": ["{workspaceRoot}/coverage/apps/frontend/admin"]
    }
  }
}
