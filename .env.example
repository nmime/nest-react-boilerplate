# Runtime
NODE_ENV=production

# API ports
ADMIN_APP_API_PORT=3001
USER_APP_API_PORT=3002
AUTH_APP_API_PORT=3003
PORT=3001

# CORS: comma-separated allowed browser origins. No wildcard is enabled in production by default.
CORS_ORIGINS=https://admin.example.com,https://app.example.com
# CORS_ORIGIN=https://app.example.com

# Auth / RBAC JWT verification. Use a high-entropy secret from your secret manager.
# AUTH_PERSISTENCE=postgres is required in production; AUTH_PERSISTENCE=memory is for tests/local-only.
AUTH_PERSISTENCE=postgres
AUTH_JWT_SECRET=<set-jwt-secret>
AUTH_JWT_ISSUER=https://auth.example.com
AUTH_JWT_AUDIENCE=nest-react-boilerplate-api
AUTH_JWT_EXPIRES_IN_SECONDS=3600
# Admin bootstrap is disabled unless explicitly enabled.
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_EMAILS=admin@example.com
ADMIN_BOOTSTRAP_TENANT_IDS=
# Expired persisted refresh/action token cleanup. Enabled by default; override only for maintenance/debugging.
# AUTH_TOKEN_CLEANUP_INTERVAL_MS values below 60000 are clamped to one minute.
AUTH_TOKEN_CLEANUP_ENABLED=true
AUTH_TOKEN_CLEANUP_INTERVAL_MS=3600000
AUTH_TOKEN_CLEANUP_RUN_ON_START=true

# OAuth / OIDC provider. OAuth state is random, stored server-side/session-bound,
# expires with a bounded TTL, and is single-use on callback. This boilerplate has
# no ID-token nonce flow until a product-specific provider exchange is wired.
# Dynamic post-login return URLs must be explicitly allowlisted in product code;
# none are accepted by default.
AUTH_OAUTH_ENABLED=false
AUTH_OAUTH_ISSUER_URL=https://issuer.example.com/
AUTH_OAUTH_CLIENT_ID=example-client-id
AUTH_OAUTH_CLIENT_SECRET=<set-oauth-client-secret>
AUTH_OAUTH_REDIRECT_URI=https://auth.example.com/oauth/callback
AUTH_OAUTH_SCOPES=openid profile email

# Backend analytics. Defaults to no-op until a real provider is selected.
# Use ANALYTICS_PROVIDER=auto to enable configured providers with complete
# credentials, or ANALYTICS_PROVIDERS for an explicit comma-separated list
# (noop, ga4, posthog, umami). Secret values must come from a secret manager.
ANALYTICS_ENABLED=false
ANALYTICS_PROVIDER=noop
# ANALYTICS_PROVIDER=auto
# ANALYTICS_PROVIDERS=ga4,posthog,umami
ANALYTICS_APP_NAME=nest-react-boilerplate-api
ANALYTICS_ENVIRONMENT=production
# ANALYTICS_GA4_MEASUREMENT_ID=<set-ga4-measurement-id>
# ANALYTICS_GA4_API_SECRET=<set-ga4-api-secret>
ANALYTICS_GA4_COLLECT_URL=https://www.google-analytics.com/mp/collect
# ANALYTICS_POSTHOG_API_KEY=<set-posthog-project-api-key>
ANALYTICS_POSTHOG_HOST=https://app.posthog.com
# ANALYTICS_UMAMI_WEBSITE_ID=<set-umami-website-id>
# ANALYTICS_UMAMI_ENDPOINT=https://umami.example.com/api/send
# ANALYTICS_UMAMI_HOST=https://umami.example.com
ANALYTICS_UMAMI_HOSTNAME=api.example.com

# Rate limiting defaults to enabled in production when RATE_LIMIT_ENABLED is unset.
# Production requires Redis/distributed storage unless RATE_LIMIT_IN_MEMORY_ALLOWED=true
# is set after equivalent ingress/API-gateway limits are configured.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORE=redis
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
REDIS_URL=redis://redis:6379/0
# REDIS_HOSTS=redis:6379
# REDIS_MODE=single
# REDIS_KEY_PREFIX=nrb:
# REDIS_DB=0
# RATE_LIMIT_IN_MEMORY_ALLOWED=false

# Fastify proxy trust is disabled by default. Set only for a known trusted proxy/ingress configuration.
TRUST_PROXY=false

# Optional OpenAPI docs. Keep disabled for public production unless access-controlled upstream.
OPENAPI_ENABLED=false
# In production, OPENAPI_ENABLED=true is ignored unless this is also true.
OPENAPI_ALLOW_PRODUCTION=false
OPENAPI_PATH=docs
OPENAPI_TITLE=Nest React Boilerplate API
OPENAPI_VERSION=1.0.0

# OpenTelemetry OTLP/HTTP exporters. Keep disabled unless a collector endpoint is configured.
OTEL_ENABLED=false
OTEL_SDK_DISABLED=false
OTEL_SERVICE_VERSION=1.0.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://otel-collector:4318/v1/traces
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://otel-collector:4318/v1/metrics
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_METRIC_EXPORT_INTERVAL=60000

# PostgreSQL / MikroORM
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nest_react_boilerplate
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nest_react_boilerplate
POSTGRES_SSL=false
POSTGRES_SSL_REJECT_UNAUTHORIZED=true
POSTGRES_SYNCHRONIZE=false
POSTGRES_LOGGING=false

# Frontend API base URLs. Empty strings use same-origin nginx/Docker proxies.
# Split-origin production builds must use explicit API origins also allowed by the SPA CSP.
# Example split origins:
# VITE_AUTH_API_BASE_URL=https://auth.example.com
# VITE_USER_API_BASE_URL=https://api.example.com
# VITE_ADMIN_API_BASE_URL=https://admin-api.example.com
# Local Vite dev can use absolute localhost URLs or run `pnpm run dev:fullstack` which sets these defaults.
VITE_AUTH_API_BASE_URL=
VITE_USER_API_BASE_URL=
VITE_ADMIN_API_BASE_URL=

# Local Docker frontend ports
ADMIN_APP_PORT=8081
USER_APP_PORT=8082
LANDING_APP_PORT=8083
