# Copy to .env.production for single-server Docker Compose or translate the same
# keys into Kubernetes Secret/ConfigMap values. Never commit real .env.production
# or files under docker/secrets/.
NODE_ENV=production
LOG_LEVEL=info

# Images. Replace the non-production placeholder with an immutable release tag
# generated from the commit you built, for example:
#   IMAGE_TAG=sha-$(git rev-parse --short=12 HEAD)
# Never use latest/main/dev/prod-style mutable tags. If your registry workflow
# pins by digest, keep the digest in a release-specific compose override and
# record it next to the Git SHA in release notes.
IMAGE_REGISTRY=ghcr.io/your-github-org/nest-react-boilerplate
IMAGE_TAG=sha-000000000000

# Single-server compose binds to 127.0.0.1 by default; put TLS/reverse proxy in
# front of these ports.
LANDING_APP_PORT=8080
ADMIN_APP_PORT=8081
USER_APP_PORT=8082
ADMIN_APP_API_PORT=3001
USER_APP_API_PORT=3002
AUTH_APP_API_PORT=3003

# Public origins and auth metadata.
CORS_ORIGINS=https://admin.example.com,https://app.example.com,https://example.com
AUTH_JWT_ISSUER=https://auth.example.com
AUTH_JWT_AUDIENCE=nest-react-boilerplate-api
AUTH_JWT_EXPIRES_IN_SECONDS=3600
AUTH_PERSISTENCE=postgres
# Expired persisted refresh/action token cleanup. Values below 60000ms are
# clamped by the service to avoid tight cleanup loops from configuration typos.
AUTH_TOKEN_CLEANUP_ENABLED=true
AUTH_TOKEN_CLEANUP_INTERVAL_MS=3600000
AUTH_TOKEN_CLEANUP_RUN_ON_START=true
# Admin bootstrap is disabled unless explicitly enabled.
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_EMAILS=admin@example.com
ADMIN_BOOTSTRAP_TENANT_IDS=

# Compose secrets are files read at container start. Create them with chmod 600.
AUTH_JWT_SECRET_FILE=./secrets/auth_jwt_secret.txt
POSTGRES_PASSWORD_FILE=./secrets/postgres_password.txt

# PostgreSQL. Compose uses the bundled database by default; Kubernetes should
# use External Secrets/Vault and either DATABASE_URL or these POSTGRES_* values.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=nest_react_boilerplate
POSTGRES_DB=nest_react_boilerplate
POSTGRES_SSL=false
POSTGRES_SSL_REJECT_UNAUTHORIZED=true
POSTGRES_SYNCHRONIZE=false
POSTGRES_LOGGING=false
# DATABASE_URL=<set-from-secret-manager-if-using-managed-db>

# OAuth is intentionally explicit and off by default. OAuth state is stored only
# server-side, bound to the current session, TTL-limited, and single-use. This
# boilerplate has no ID-token nonce flow until a provider exchange is wired.
# Product-specific dynamic return URLs must be exactly allowlisted in code.
AUTH_OAUTH_ENABLED=false
AUTH_OAUTH_ISSUER_URL=https://issuer.example.com/
AUTH_OAUTH_CLIENT_ID=<set-client-id>
AUTH_OAUTH_CLIENT_SECRET=<set-from-secret-manager>
AUTH_OAUTH_REDIRECT_URI=https://auth.example.com/oauth/callback
AUTH_OAUTH_SCOPES=openid profile email

# Backend analytics. Defaults to no-op until a real provider is selected.
# Use ANALYTICS_PROVIDER=auto to enable configured providers with complete
# credentials, or ANALYTICS_PROVIDERS for an explicit comma-separated list
# (noop, ga4, posthog, umami). Secret values must come from a secret manager.
ANALYTICS_ENABLED=false
ANALYTICS_PROVIDER=noop
# ANALYTICS_PROVIDER=auto
# ANALYTICS_PROVIDERS=ga4,posthog,umami
ANALYTICS_APP_NAME=nest-react-boilerplate-api
ANALYTICS_ENVIRONMENT=production
# ANALYTICS_GA4_MEASUREMENT_ID=<set-ga4-measurement-id>
# ANALYTICS_GA4_API_SECRET=<set-ga4-api-secret>
ANALYTICS_GA4_COLLECT_URL=https://www.google-analytics.com/mp/collect
# ANALYTICS_POSTHOG_API_KEY=<set-posthog-project-api-key>
ANALYTICS_POSTHOG_HOST=https://app.posthog.com
# ANALYTICS_UMAMI_WEBSITE_ID=<set-umami-website-id>
# ANALYTICS_UMAMI_ENDPOINT=https://umami.example.com/api/send
# ANALYTICS_UMAMI_HOST=https://umami.example.com
ANALYTICS_UMAMI_HOSTNAME=api.example.com

# Shared rate limiting. The production Docker Compose profile starts Redis and
# uses it by default; Kubernetes/managed deployments can set REDIS_URL or
# REDIS_HOSTS. Set RATE_LIMIT_STORE=memory only for single-process deployments
# with equivalent ingress/API-gateway limits.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORE=redis
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
REDIS_URL=redis://redis:6379/0
REDIS_KEY_PREFIX=nrb:
RATE_LIMIT_IN_MEMORY_ALLOWED=false
# REDIS_MODE=single
# REDIS_HOSTS=redis:6379
# REDIS_DB=0
OPENAPI_ENABLED=false
OPENAPI_ALLOW_PRODUCTION=false
OPENAPI_PATH=docs

# Browser-facing build-time values for frontend images. Production frontend
# builds fail fast unless these explicit origins are set, or you deliberately
# opt into same-origin API proxying with VITE_API_BASE_URL_MODE=same-origin.
# The standalone SPA CSP permits these same explicit API origins.
VITE_AUTH_API_BASE_URL=https://auth.example.com
VITE_USER_API_BASE_URL=https://api.example.com
VITE_ADMIN_API_BASE_URL=https://admin-api.example.com
# VITE_API_BASE_URL_MODE=same-origin
