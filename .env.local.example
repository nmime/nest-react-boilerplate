NODE_ENV=development
PORT=3001
ADMIN_APP_API_PORT=3001
USER_APP_API_PORT=3002
AUTH_APP_API_PORT=3003
CORS_ORIGINS=http://localhost:4200,http://localhost:4201,http://localhost:4202
AUTH_JWT_SECRET=local-development-secret-change-me
AUTH_JWT_ISSUER=http://localhost:3003
AUTH_JWT_AUDIENCE=nest-react-boilerplate-api
# Admin bootstrap is disabled unless explicitly enabled.
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_EMAILS=admin@example.com
ADMIN_BOOTSTRAP_TENANT_IDS=
OPENAPI_ENABLED=true
OPENAPI_PATH=docs

# Backend analytics defaults to no-op locally. Uncomment provider placeholders
# when testing against a real analytics backend; never commit real secrets.
ANALYTICS_ENABLED=true
ANALYTICS_PROVIDER=noop
ANALYTICS_APP_NAME=nest-react-boilerplate-api
ANALYTICS_ENVIRONMENT=development
# ANALYTICS_POSTHOG_API_KEY=<set-posthog-project-api-key>
# ANALYTICS_POSTHOG_HOST=https://app.posthog.com
# ANALYTICS_UMAMI_WEBSITE_ID=<set-umami-website-id>
# ANALYTICS_UMAMI_ENDPOINT=http://localhost:3000/api/send
# ANALYTICS_UMAMI_HOST=http://localhost:3000
# ANALYTICS_GA4_MEASUREMENT_ID=<set-ga4-measurement-id>
# ANALYTICS_GA4_API_SECRET=<set-ga4-api-secret>

DATABASE_URL=postgres://postgres:postgres@localhost:5432/nest_react_boilerplate
POSTGRES_SYNCHRONIZE=false
POSTGRES_LOGGING=true
VITE_AUTH_API_BASE_URL=http://localhost:3003
VITE_USER_API_BASE_URL=http://localhost:3002
VITE_ADMIN_API_BASE_URL=http://localhost:3001
LOG_LEVEL=debug
