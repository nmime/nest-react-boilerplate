{
  "name": "@app/postgres-main-feature-flags",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/postgres/main/feature-flags/lib/src",
  "projectType": "library",
  "tags": [
    "platform:backend",
    "type:data-access",
    "scope:postgres",
    "scope:feature-flags"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/postgres/main/feature-flags",
        "main": "libs/postgres/main/feature-flags/lib/src/index.ts",
        "tsConfig": "libs/postgres/main/feature-flags/lib/tsconfig.lib.json",
        "assets": []
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "cwd": "libs/postgres/main/feature-flags/lib",
        "command": "vitest run --config vitest.config.mts"
      },
      "inputs": [
        "default",
        "^production",
        { "externalDependencies": ["vitest"] }
      ],
      "outputs": ["{workspaceRoot}/coverage/libs/postgres/main/feature-flags"]
    }
  }
}
