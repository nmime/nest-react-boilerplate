# Environment example
# Copy to .env (or .env.local for local development) and replace placeholders.
# Do not commit real secrets, tokens, private keys, or production .env files.
# .env.example and .env.local.example intentionally keep identical active key order.
# Profile: local development

# Runtime identity
# Required/optional runtime setting; replace placeholders per environment.
APP_NAME=nest-react-boilerplate
# Optional QA/workflow override.
CI=false
# Required/optional runtime setting; replace placeholders per environment.
CONTAINER=
# Required/optional runtime setting; replace placeholders per environment.
GRACEFUL_SHUTDOWN=true
# Required/optional runtime setting; replace placeholders per environment.
HOST=127.0.0.1
# Required/optional runtime setting; replace placeholders per environment.
KUBERNETES_SERVICE_HOST=
# Required/optional runtime setting; replace placeholders per environment.
LOGGER_FORMAT=pretty
# Required/optional runtime setting; replace placeholders per environment.
LOG_FORMAT=pretty
# Required/optional runtime setting; replace placeholders per environment.
LOG_LEVEL=debug
# Required/optional runtime setting; replace placeholders per environment.
NODE_ENV=development
# Required/optional runtime setting; replace placeholders per environment.
PORT=3001

# API ports and browser origins
# Required/optional runtime setting; replace placeholders per environment.
ADMIN_APP_API_PORT=3001
# Required/optional runtime setting; replace placeholders per environment.
ADMIN_APP_PORT=4200
# Required/optional runtime setting; replace placeholders per environment.
AUTH_APP_API_PORT=3003
# Required/optional runtime setting; replace placeholders per environment.
CORS_ORIGINS=http://localhost:4200,http://localhost:4201,http://localhost:4202
# Required/optional runtime setting; replace placeholders per environment.
FULLSTACK_BASE_URL=
# Required/optional runtime setting; replace placeholders per environment.
FULLSTACK_HOST=127.0.0.1
# Required/optional runtime setting; replace placeholders per environment.
LANDING_APP_PORT=4202
# Required/optional runtime setting; replace placeholders per environment.
TRUST_PROXY=false
# Required/optional runtime setting; replace placeholders per environment.
USER_APP_API_PORT=3002
# Required/optional runtime setting; replace placeholders per environment.
USER_APP_PORT=4201
# Required/optional runtime setting; replace placeholders per environment.
USER_APP_URL=

# Session cookies
# Required/optional runtime setting; replace placeholders per environment.
SESSION_COOKIE_MAX_AGE_SECONDS=604800
# Required/optional runtime setting; replace placeholders per environment.
SESSION_COOKIE_NAME=nrb.sid
# Required/optional runtime setting; replace placeholders per environment.
SESSION_COOKIE_SAME_SITE=lax
# Required/optional runtime setting; replace placeholders per environment.
SESSION_COOKIE_SECURE=false
# Required/secret placeholder when enabled; never commit a real value.
SESSION_SECRET=

# Auth, RBAC, and token cleanup
# Required/optional runtime setting; replace placeholders per environment.
ADMIN_BOOTSTRAP_EMAILS=admin@example.com
# Required/optional runtime setting; replace placeholders per environment.
ADMIN_BOOTSTRAP_ENABLED=false
# Required/optional runtime setting; replace placeholders per environment.
ADMIN_BOOTSTRAP_TENANT_IDS=
# Required/optional runtime setting; replace placeholders per environment.
AUTH_JWT_AUDIENCE=nest-react-boilerplate-api
# Required/optional runtime setting; replace placeholders per environment.
AUTH_JWT_EXPIRES_IN_SECONDS=3600
# Required/optional runtime setting; replace placeholders per environment.
AUTH_JWT_ISSUER=http://localhost:3003
# Required/secret placeholder when enabled; never commit a real value.
AUTH_JWT_SECRET=<local-jwt-secret>
# Prod-only secret-file path for Docker/Compose secret mounting.
AUTH_JWT_SECRET_FILE=
# Required/optional runtime setting; replace placeholders per environment.
AUTH_PERSISTENCE=postgres
# Required/optional runtime setting; replace placeholders per environment.
AUTH_TOKEN_CLEANUP_ENABLED=true
# Required/optional runtime setting; replace placeholders per environment.
AUTH_TOKEN_CLEANUP_INTERVAL_MS=3600000
# Required/optional runtime setting; replace placeholders per environment.
AUTH_TOKEN_CLEANUP_RUN_ON_START=true

# Social auth, Telegram Mini App, bots, and Discord
# Optional social-auth policy; enable only after provider runtime is implemented and configured.
EXTERNAL_AUTH_AUTO_PROVISION_ENABLED=false
# Optional social-auth policy; maximum age for step-up confirmation before link/unlink.
EXTERNAL_AUTH_STEP_UP_MAX_AGE_SECONDS=900
# Optional social-auth policy; signed link-token lifetime.
EXTERNAL_AUTH_LINK_TOKEN_TTL_SECONDS=600
# Optional social-auth policy; OAuth/TMA state lifetime.
EXTERNAL_AUTH_STATE_TTL_SECONDS=600
# Required/secret placeholder when provider refresh/access tokens are stored.
AUTH_PROVIDER_TOKEN_ENCRYPTION_KEY=<local-32-byte-base64-key>
# Prod-only secret-file path for Docker/Compose secret mounting.
AUTH_PROVIDER_TOKEN_ENCRYPTION_KEY_FILE=
# Optional provider encryption key identifier for rotation.
AUTH_PROVIDER_TOKEN_ENCRYPTION_KEY_ID=primary
# Optional Telegram social auth/TMA setting.
TELEGRAM_AUTH_ENABLED=false
# Optional Telegram auth bot username without @.
TELEGRAM_AUTH_BOT_USERNAME=example_bot
# Optional Telegram init-data max age.
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400
# Optional Telegram replay-cache TTL.
TELEGRAM_AUTH_REPLAY_TTL_SECONDS=900
# Required/secret placeholder when Telegram bot/social auth is enabled.
TELEGRAM_BOT_TOKEN=<local-telegram-bot-token>
# Prod-only secret-file path for Docker/Compose secret mounting.
TELEGRAM_BOT_TOKEN_FILE=
# Optional Telegram bot username without @.
TELEGRAM_BOT_USERNAME=example_bot
# Optional Telegram bot webhook secret token when webhook mode is enabled.
TELEGRAM_BOT_WEBHOOK_SECRET=<local-telegram-webhook-secret>
# Prod-only secret-file path for Docker/Compose secret mounting.
TELEGRAM_BOT_WEBHOOK_SECRET_FILE=
# Optional Telegram bot runtime mode: webhook or polling.
TELEGRAM_BOT_MODE=webhook
# Optional Telegram bot webhook URL.
TELEGRAM_BOT_WEBHOOK_URL=http://localhost:3003/bots/telegram/webhook
# Optional Telegram Mini App/Open App frontend URL. Use an HTTPS user frontend route, not an API/webhook URL.
# For local Telegram testing expose this route through a Telegram-compatible HTTPS tunnel.
# Canonical Telegram Mini App/Open App frontend URL consumed by the bot.
TELEGRAM_MINI_APP_URL=http://localhost:4200/telegram-mini-app
# Optional Telegram account-link token TTL.
# Optional persistent Telegram chat menu button setup; safe no-op when Mini App URL is absent.
TELEGRAM_BOT_MENU_BUTTON_ENABLED=false
TELEGRAM_LINK_TOKEN_TTL_SECONDS=600
# Optional Discord OAuth/social auth setting.
DISCORD_AUTH_ENABLED=false
# Optional Discord OAuth application/client id.
DISCORD_CLIENT_ID=example-discord-client-id
# Required/secret placeholder when Discord OAuth is enabled.
DISCORD_CLIENT_SECRET=<local-discord-client-secret>
# Prod-only secret-file path for Docker/Compose secret mounting.
DISCORD_CLIENT_SECRET_FILE=
# Optional Discord OAuth redirect URI.
DISCORD_REDIRECT_URI=http://localhost:3003/social/discord/callback
# Optional Discord OAuth scopes.
DISCORD_SCOPES=identify email guilds.join
# Required/secret placeholder when the Discord bot is enabled.
DISCORD_BOT_TOKEN=<local-discord-bot-token>
# Prod-only secret-file path for Docker/Compose secret mounting.
DISCORD_BOT_TOKEN_FILE=
# Optional Discord interactions public key for signature verification.
DISCORD_PUBLIC_KEY=<local-discord-public-key>
# Prod-only public-key file path for Docker/Compose mounting.
DISCORD_PUBLIC_KEY_FILE=
# Optional Discord command registration toggle.
DISCORD_COMMAND_REGISTRATION_ENABLED=false
# Optional Discord interactions endpoint URL.
DISCORD_INTERACTIONS_ENDPOINT=http://localhost:3003/bots/discord/interactions
# Optional Discord interactions state TTL.
DISCORD_INTERACTIONS_STATE_TTL_SECONDS=600

# OAuth / OIDC
# Optional integration setting; enable only with matching infrastructure.
AUTH_OAUTH_CLIENT_ID=local-client-id
# Required/secret placeholder when enabled; never commit a real value.
AUTH_OAUTH_CLIENT_SECRET=<local-oauth-client-secret>
# Optional integration setting; enable only with matching infrastructure.
AUTH_OAUTH_ENABLED=false
# Optional integration setting; enable only with matching infrastructure.
AUTH_OAUTH_ISSUER_URL=http://localhost:3003/oauth
# Optional integration setting; enable only with matching infrastructure.
AUTH_OAUTH_REDIRECT_URI=http://localhost:3003/oauth/callback
# Optional integration setting; enable only with matching infrastructure.
AUTH_OAUTH_SCOPES=openid profile email

# Analytics
# Optional integration setting; enable only with matching infrastructure.
ANALYTICS_APP_NAME=nest-react-boilerplate-api
# Optional integration setting; enable only with matching infrastructure.
ANALYTICS_ENABLED=true
# Optional integration setting; enable only with matching infrastructure.
ANALYTICS_ENVIRONMENT=development
# Required/secret placeholder when enabled; never commit a real value.
ANALYTICS_GA4_API_SECRET=
# Optional integration setting; enable only with matching infrastructure.
ANALYTICS_GA4_COLLECT_URL=https://www.google-analytics.com/mp/collect
# Optional integration setting; enable only with matching infrastructure.
ANALYTICS_GA4_MEASUREMENT_ID=
# Required/secret placeholder when enabled; never commit a real value.
ANALYTICS_POSTHOG_API_KEY=
# Optional integration setting; enable only with matching infrastructure.
ANALYTICS_POSTHOG_HOST=https://app.posthog.com
# Optional integration setting; enable only with matching infrastructure.
ANALYTICS_PROVIDER=noop
# Optional integration setting; enable only with matching infrastructure.
ANALYTICS_PROVIDERS=
# Optional integration setting; enable only with matching infrastructure.
ANALYTICS_UMAMI_ENDPOINT=
# Optional integration setting; enable only with matching infrastructure.
ANALYTICS_UMAMI_HOST=
# Optional integration setting; enable only with matching infrastructure.
ANALYTICS_UMAMI_HOSTNAME=localhost
# Optional integration setting; enable only with matching infrastructure.
ANALYTICS_UMAMI_WEBSITE_ID=

# Rate limiting and Redis
# Optional integration setting; enable only with matching infrastructure.
RATE_LIMIT_ENABLED=true
# Optional integration setting; enable only with matching infrastructure.
RATE_LIMIT_IN_MEMORY_ALLOWED=true
# Optional integration setting; enable only with matching infrastructure.
RATE_LIMIT_MAX=100
# Optional integration setting; enable only with matching infrastructure.
RATE_LIMIT_STORE=memory
# Optional integration setting; enable only with matching infrastructure.
RATE_LIMIT_WINDOW_MS=60000
# Optional integration setting; enable only with matching infrastructure.
REDIS_DB=0
# Optional integration setting; enable only with matching infrastructure.
REDIS_HOSTS=
# Optional integration setting; enable only with matching infrastructure.
REDIS_KEY_PREFIX=nrb-local:
# Optional integration setting; enable only with matching infrastructure.
REDIS_MODE=single
# Required/secret placeholder when enabled; never commit a real value.
REDIS_PASSWORD=
# Optional integration setting; enable only with matching infrastructure.
REDIS_SENTINEL_GROUP_IDENTIFIER=
# Optional integration setting; enable only with matching infrastructure.
REDIS_URL=

# NATS messaging
# Optional integration setting; enable only with matching infrastructure.
NATS_DRAIN_TIMEOUT_MS=5000
# Optional integration setting; enable only with matching infrastructure.
NATS_MAX_RECONNECT_ATTEMPTS=3
# Optional integration setting; enable only with matching infrastructure.
NATS_NAME=nest-react-boilerplate-local
# Required/secret placeholder when enabled; never commit a real value.
NATS_PASS=
# Optional integration setting; enable only with matching infrastructure.
NATS_PING_INTERVAL_MS=120000
# Optional integration setting; enable only with matching infrastructure.
NATS_RECONNECT=true
# Optional integration setting; enable only with matching infrastructure.
NATS_RECONNECT_TIME_WAIT_MS=1000
# Optional integration setting; enable only with matching infrastructure.
NATS_SERVERS=
# Optional integration setting; enable only with matching infrastructure.
NATS_TIMEOUT_MS=2000
# Optional integration setting; enable only with matching infrastructure.
NATS_USER=
# Optional integration setting; enable only with matching infrastructure.
NATS_WAIT_ON_FIRST_CONNECT=false

# OpenAPI and API contracts
# Required/optional runtime setting; replace placeholders per environment.
API_CONTRACTS_WORKSPACE_ROOT=.
# Required/optional runtime setting; replace placeholders per environment.
CONSUMER_CONTRACTS_ROOT=contracts/consumer
# Optional integration setting; enable only with matching infrastructure.
OPENAPI_ALLOW_PRODUCTION=false
# Optional integration setting; enable only with matching infrastructure.
OPENAPI_CONTRACTS_ROOT=apps/backend
# Optional integration setting; enable only with matching infrastructure.
OPENAPI_DESCRIPTION=
# Optional integration setting; enable only with matching infrastructure.
OPENAPI_ENABLED=true
# Optional integration setting; enable only with matching infrastructure.
OPENAPI_FUZZ_ENGINE=schemathesis
# Optional integration setting; enable only with matching infrastructure.
OPENAPI_FUZZ_MAX_EXAMPLES=25
# Optional integration setting; enable only with matching infrastructure.
OPENAPI_FUZZ_TIMEOUT_MS=30000
# Optional integration setting; enable only with matching infrastructure.
OPENAPI_FUZZ_UNSAFE=false
# Optional integration setting; enable only with matching infrastructure.
OPENAPI_LINT_ENGINE=spectral
# Optional integration setting; enable only with matching infrastructure.
OPENAPI_PATH=docs
# Optional integration setting; enable only with matching infrastructure.
OPENAPI_TITLE=Nest React Boilerplate API
# Optional integration setting; enable only with matching infrastructure.
OPENAPI_VERSION=1.0.0
# Required/optional runtime setting; replace placeholders per environment.
SPECTRAL_CLI_VERSION=6.15.0

# OpenTelemetry
# Optional integration setting; enable only with matching infrastructure.
OTEL_ENABLED=false
# Optional integration setting; enable only with matching infrastructure.
OTEL_EXPORTER_OTLP_ENDPOINT=
# Required/secret placeholder when enabled; never commit a real value.
OTEL_EXPORTER_OTLP_HEADERS=
# Optional integration setting; enable only with matching infrastructure.
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=
# Optional integration setting; enable only with matching infrastructure.
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
