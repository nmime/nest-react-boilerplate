{
  "name": "@app/postgres-main",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/postgres/main/shared/lib/src",
  "projectType": "library",
  "tags": ["platform:backend", "type:data-access", "scope:postgres"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/postgres/main/shared",
        "main": "libs/postgres/main/shared/lib/src/index.ts",
        "tsConfig": "libs/postgres/main/shared/lib/tsconfig.lib.json",
        "assets": [],
        "rootDir": "."
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "cwd": "libs/postgres/main/shared/lib",
        "command": "vitest run --config vitest.config.mts"
      },
      "inputs": [
        "default",
        "^production",
        { "externalDependencies": ["vitest"] }
      ],
      "outputs": ["{workspaceRoot}/coverage/libs/postgres/main/shared"]
    }
  }
}
