# Runtime
NODE_ENV=production

# API ports
ADMIN_APP_API_PORT=3001
USER_APP_API_PORT=3002
AUTH_APP_API_PORT=3003
PORT=3001

# CORS: comma-separated allowed browser origins. No wildcard is enabled in production by default.
CORS_ORIGINS=https://admin.example.com,https://app.example.com
# CORS_ORIGIN=https://app.example.com

# Auth / RBAC JWT verification. Use a high-entropy secret from your secret manager.
AUTH_JWT_SECRET=<set-a-strong-random-jwt-secret>
AUTH_JWT_ISSUER=https://auth.example.com
AUTH_JWT_AUDIENCE=nest-react-boilerplate-api
AUTH_JWT_EXPIRES_IN_SECONDS=3600
ADMIN_BOOTSTRAP_EMAILS=admin@example.com

# OAuth / OIDC provider
AUTH_OAUTH_ENABLED=false
AUTH_OAUTH_ISSUER_URL=https://issuer.example.com/
AUTH_OAUTH_CLIENT_ID=example-client-id
AUTH_OAUTH_CLIENT_SECRET=<set-oauth-client-secret>
AUTH_OAUTH_REDIRECT_URI=https://auth.example.com/oauth/callback
AUTH_OAUTH_SCOPES=openid profile email

# Production in-memory per-instance rate limiting defaults to enabled when RATE_LIMIT_ENABLED is unset.
# Use an upstream/Redis-backed limiter for shared multi-instance enforcement.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Fastify proxy trust is disabled by default. Set only for a known trusted proxy/ingress configuration.
TRUST_PROXY=false

# Optional OpenAPI docs. Keep disabled for public production unless access-controlled upstream.
OPENAPI_ENABLED=false
OPENAPI_PATH=docs
OPENAPI_TITLE=Nest React Boilerplate API
OPENAPI_VERSION=1.0.0

# PostgreSQL / MikroORM
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nest_react_boilerplate
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nest_react_boilerplate
POSTGRES_SSL=false
POSTGRES_SSL_REJECT_UNAUTHORIZED=true
POSTGRES_SYNCHRONIZE=false
POSTGRES_LOGGING=false

# Frontend API base URLs. Empty strings use same-origin nginx/Docker proxies.
# Local Vite dev can use absolute URLs or run `pnpm run dev:fullstack` which sets these defaults.
VITE_AUTH_API_BASE_URL=
VITE_USER_API_BASE_URL=
VITE_ADMIN_API_BASE_URL=

# Local Docker frontend ports
ADMIN_APP_PORT=8081
USER_APP_PORT=8082
LANDING_APP_PORT=8083
