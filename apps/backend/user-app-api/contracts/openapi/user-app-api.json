  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      },
      "nrb.sid": {
        "type": "apiKey",
        "in": "cookie",
        "name": "nrb.sid",
        "description": "Development/default HTTP session cookie. SESSION_COOKIE_NAME may override the runtime name."
      },
      "__Host-nrb.sid": {
        "type": "apiKey",
        "in": "cookie",
        "name": "__Host-nrb.sid",
        "description": "Production default HTTPS session cookie. SESSION_COOKIE_NAME may override the runtime name."
      }
    },
    "schemas": {
      "AuthenticatedPrincipalDto": {
        "type": "object",
        "properties": {
          "subject": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "displayName": {
            "type": "string"
          },
          "locale": {
            "type": "string",
            "enum": ["en", "ru"]
          },
          "issuer": {
            "type": "string"
          },
          "audience": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              }
            ]
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tokenId": {
            "type": "string"
          }
        },
        "required": ["subject", "roles", "permissions"]
      },
      "UserProfileViewDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "displayName": {
            "type": "string"
          },
          "locale": {
            "type": "string",
            "enum": ["en", "ru"]
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["id", "roles", "permissions"]
      },
      "ProfilePayloadDto": {
        "type": "object",
        "properties": {
          "principal": {
            "$ref": "#/components/schemas/AuthenticatedPrincipalDto"
          },
          "profile": {
            "$ref": "#/components/schemas/UserProfileViewDto"
          }
        },
        "required": ["principal", "profile"]
      }
    }
  }
