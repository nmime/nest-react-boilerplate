{
  "name": "@app/frontend/feature-admin-shared",
  "$schema": "../../../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/frontend/feature/admin/shared/lib/src",
  "projectType": "library",
  "tags": [
    "platform:frontend",
    "type:feature-shared",
    "scope:admin",
    "fsd:layer:shared"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/frontend/feature/admin/shared",
        "main": "libs/frontend/feature/admin/shared/lib/src/index.ts",
        "tsConfig": "libs/frontend/feature/admin/shared/lib/tsconfig.lib.json",
        "assets": []
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "cwd": "libs/frontend/feature/admin/shared/lib",
        "command": "vitest run --config vitest.config.mts"
      },
      "inputs": [
        "default",
        "^production",
        {
          "externalDependencies": ["vitest"]
        }
      ],
      "outputs": ["{workspaceRoot}/coverage/libs/frontend/feature/admin/shared"]
    }
  }
}
