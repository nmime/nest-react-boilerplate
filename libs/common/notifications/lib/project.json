{
  "name": "@app/common/notifications",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/common/notifications/lib/src",
  "projectType": "library",
  "tags": [
    "platform:shared",
    "type:common",
    "scope:shared",
    "boundary:notifications",
    "boundary:contracts",
    "framework:neutral"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/common/notifications",
        "main": "libs/common/notifications/lib/src/index.ts",
        "tsConfig": "libs/common/notifications/lib/tsconfig.lib.json",
        "assets": []
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "cwd": "libs/common/notifications/lib",
        "command": "vitest run --config vitest.config.mts"
      },
      "inputs": [
        "default",
        "^production",
        { "externalDependencies": ["vitest"] }
      ],
      "outputs": ["{workspaceRoot}/coverage/libs/common/notifications"]
    }
  }
}
